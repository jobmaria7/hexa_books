import sys
import hashlib

def testar_compressao(dados_originais, algoritmo_de_compressao, algoritmo_de_descompressao):
    # 1. Medir tamanho original
    tamanho_original = sys.getsizeof(dados_originais)
    
    # 2. Executar a "Tua Magia" (Compressão)
    dados_comprimidos = algoritmo_de_compressao(dados_originais)
    tamanho_comprimido = sys.getsizeof(dados_comprimidos)
    
    # 3. Executar o processo inverso (Descompressão)
    dados_recuperados = algoritmo_de_descompressao(dados_comprimidos)
    
    # 4. VERIFICAÇÃO DE INTEGRIDADE (O "Momento Richard Hendricks")
    # Geramos um "impressão digital" (hash) de ambos os ficheiros
    hash_original = hashlib.sha256(dados_originais.encode()).hexdigest()
    hash_final = hashlib.sha256(dados_recuperados.encode()).hexdigest()
    
    # 5. RESULTADOS
    print(f"--- Relatório Pied Piper ---")
    print(f"Tamanho Original: {tamanho_original} bytes")
    print(f"Tamanho Comprimido: {tamanho_comprimido} bytes")
